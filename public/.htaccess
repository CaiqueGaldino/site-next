# Configuração para Next.js Static Export no Apache/cPanel

Options -MultiViews
RewriteEngine On

# 1. Forçar HTTPS (Opcional, mas recomendado)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Remover .html da URL
# Exemplo: fitnessexclusive.com.br/investidor.html -> fitnessexclusive.com.br/investidor
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# 3. Servir arquivos .html sem mostrar a extensão
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

# 4. Lidar com Trailing Slash (Configurado como true no next.config.ts)
# Mapeia /pagina/ para /pagina.html ou /pagina/index.html
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.*)/$ $1/index.html [L]

# 5. Página de Erro 404 Personalizada
ErrorDocument 404 /404.html
